<h1>New Place</h1>
<% @user = User.find_by({ "id" => session["user_id"] }) %>

<% if @user != nil %>
<form action="/places" method="post">
  <p>
    <label for="name_input">Name</label>
    <input type="text" name="name" id="name_input">
  </p>

  <button>Save</button>
</form>
<% else %>
  You must first <a href="/login">login</a> to post.
<% end %>