
<% @user = User.find_by({ "id" => session["user_id"] }) %>



<% if @user != nil %>
<h1> <%= @user["username"] %>, these are the places you've been:</h1> 

<ul>
  <% for place in @places %>
    <li><a href="/places/<%= place["id"] %>"><%= place["name"] %></a></li>
  <% end %>
</ul>

<p>
  <a href="/places/new">Add a destination</a>
</p>


<% else %>
  Click here to <a href="/login">login</a>.
<% end %>